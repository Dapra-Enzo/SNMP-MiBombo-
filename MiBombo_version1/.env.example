# ============================================
# MiBombo Station - Environment Template
# ============================================
# INSTRUCTIONS:
# 1. Copiez ce fichier vers .env : cp .env.example .env
# 2. Remplissez les valeurs manquantes avec vos secrets
# 3. Ne commitez JAMAIS le fichier .env final ! L'entreprise ENSA n'est est pas responsable de vos actions
# ============================================

# FLASK API
# Générer avec : python -c 'import secrets; print(secrets.token_urlsafe(32))'
FLASK_SECRET_KEY=change_me_in_production

# DATABASE
DB_PASSWORD=change_me

# INFLUXDB (Si utilisé)
INFLUXDB_TOKEN=my-super-secret-admin-token
INFLUXDB_ORG=mibombo-org
INFLUXDB_BUCKET=mibombo-bucket
INFLUXDB_URL=http://localhost:8086

# ENCRYPTION KEYS
# Générer avec le même script que FLASK_SECRET_KEY ou Cryptography
AUTH_KEY=change_me_base64_key
SNIFFER_KEY=change_me_base64_key
ENCRYPTION_KEY=change_me_base64_key

# MAIL CONFIG (Gmail ou autre SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@gmail.com
